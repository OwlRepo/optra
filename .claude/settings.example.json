{
  "description": "Example Claude Code settings for this project. The active copy is settings.json (schema verified in this environment). Claude Code implements directly in this repo (single-agent setup) — source edits are gated by the predict-verify hook, not disabled.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-gstack.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-predict-verify.sh\""
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-plan-gate.sh\""
          }
        ]
      }
    ]
  }
}
