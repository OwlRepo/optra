# Environment files - loaded via env_file: in docker-compose
# Runtime env vars come from docker-compose.prod.yml
.env*
!.env.example
*.md
!README.md
.vscode
.idea
*.log
# Scoped to real Jest/Vitest coverage-report output (apps/*/coverage,
# packages/*/coverage). A bare "coverage"/"**/coverage" also matched the
# app route folder apps/web/app/api/workspaces/[id]/insights/coverage/,
# silently excluding it from the Docker build context and 404ing that
# route in production only — see docs/ai/risk-register.md.
/apps/*/coverage
/packages/*/coverage
.DS_Store
*.swp
*.swo
*.tsbuildinfo
**/*.tsbuildinfo
.gstack
Dockerfile
docker-compose*.yml
