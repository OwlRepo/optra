# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:54321/support_brain

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
CHAT_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_THRESHOLD=0.95
CHAT_RATE_LIMIT_PER_MIN_PER_USER=20
CHAT_RATE_LIMIT_PER_MIN_PER_WORKSPACE=200
MAX_TOKENS_PER_WORKSPACE_MONTH=5000000

# S3-compatible object storage (SeaweedFS locally)
S3_ENDPOINT=http://localhost:8333
S3_REGION=us-east-1
S3_ACCESS_KEY=mnemra-local
S3_SECRET_KEY=mnemra-local-secret
S3_BUCKET=mnemra-documents
S3_FORCE_PATH_STYLE=true

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# LangSmith (optional)
LANGSMITH_API_KEY=ls__your-key-here
LANGSMITH_PROJECT=support-second-brain
RAGAS_JUDGE_MODEL=gpt-4-turbo

# Conditional LangGraph RAG
LANGGRAPH_ENABLED=false
RETRIEVAL_SCORE_THRESHOLD=0.78
MAX_QUERY_REWRITES=2
SELF_GRADE_ENABLED=false

# Next.js Public URLs
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth (read by apps/api auth module + jwt strategy)
JWT_SECRET=change-me-in-prod
JWT_EXPIRY=15m

# Email OTP via Resend. EMAIL_OTP_ENABLED=false -> OTP prints to API console as "[DEV OTP] <email> -> <code>"
EMAIL_OTP_ENABLED=false
RESEND_API_KEY=re_your-key-here
RESEND_FROM_EMAIL=noreply@mnemra.com

# Backend URL used by Next.js server-side proxy routes (apps/web/app/api/*)
API_URL=http://localhost:3001

# Public web app URL — used to build workspace invite links.
WEB_URL=http://localhost:3000

# Scrape quota + crawler identification
MAX_DOCS_PER_WORKSPACE=5000
CRAWLER_USER_AGENT=MnemraBot/1.0 (+https://mnemra.com/bot)
MAX_UPLOAD_MB=25

# Production only (not needed for local dev)
# DOMAIN=your-domain.com
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=secure-password
# POSTGRES_DB=support_brain
