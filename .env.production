# Production environment - DO NOT COMMIT
# Copy to .env.prod and fill in values

# Domain (your Squarespace domain pointing to Hetzner)
DOMAIN=your-domain.com

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=support_brain

# OpenAI
OPENAI_API_KEY=sk-your-production-key

# LangSmith (optional)
LANGSMITH_API_KEY=ls__your-key
LANGSMITH_PROJECT=support-second-brain-prod
