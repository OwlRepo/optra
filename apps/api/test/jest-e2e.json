{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "@swc/jest"
  },
  "transformIgnorePatterns": [
    "/node_modules/(?!(p-limit|yocto-queue)/)"
  ],
  "moduleNameMapper": {
    "^@repo/(ai|db|types)$": "<rootDir>/../../../packages/$1/dist"
  }
}
